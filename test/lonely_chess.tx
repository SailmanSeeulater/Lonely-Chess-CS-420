/*
 * Lonely Chess - TextX Grammar (v6)
 *
 * Key fix: PieceDisambigFile is now only matched when a capture 'x' is
 * present between from_file and to_file (e.g. Naxb3), OR when both a
 * from_file AND from_rank are present (handled by PieceDisambigBoth).
 * This prevents Na3 from being mis-parsed as N(from=a) + missing-dest.
 *
 * Ordering:
 *   1. PieceDisambigBoth   — Qd1h5  (file+rank+dest)
 *   2. PieceDisambigFile   — Naxb3  (file+capture+dest)  capture required
 *   3. PieceOnly           — Na3, Ra6, Qxh5
 *   4. PawnCapture         — exd5
 *   5. PawnPush            — h4, a6
 */

PGNGame:
    headers+=Header
    moves+=MoveEntry
    result=Result
;

Header:
    '[' key=ID value=QuotedString ']'
;

MoveEntry:
    number=INT '.'
    white=HalfMove
    (black=HalfMove)?
;

HalfMove:
      CastleMove
    | RegularMove
;

CastleMove:
    castle=CastleType check?=CheckSuffix
;

CastleType:
    'O-O-O' | 'O-O'
;

RegularMove:
      PieceDisambigBoth
    | PieceDisambigCapture
    | PieceOnly
    | PawnCapture
    | PawnPush
;

// e.g. Qd1h5  R1a3  (piece + from_file + from_rank + [x] + dest)
PieceDisambigBoth:
    piece=PieceLetter
    from_file=FILE_LETTER
    from_rank=RANK_DIGIT
    capture?='x'
    to_file=FILE_LETTER
    to_rank=RANK_DIGIT
    promotion?=PromotionSuffix
    check?=CheckSuffix
;

// e.g. Naxb3  Rcxd5  (piece + from_file + capture 'x' + dest)
// capture 'x' is REQUIRED so this never matches Na3 (no x present)
PieceDisambigCapture:
    piece=PieceLetter
    from_file=FILE_LETTER
    'x'
    to_file=FILE_LETTER
    to_rank=RANK_DIGIT
    promotion?=PromotionSuffix
    check?=CheckSuffix
;

// e.g. Na3  Ra6  Qxh5  Nc4  Nb1
PieceOnly:
    piece=PieceLetter
    capture?='x'
    to_file=FILE_LETTER
    to_rank=RANK_DIGIT
    promotion?=PromotionSuffix
    check?=CheckSuffix
;

// e.g. exd5  fxg6
PawnCapture:
    from_file=FILE_LETTER
    'x'
    to_file=FILE_LETTER
    to_rank=RANK_DIGIT
    promotion?=PromotionSuffix
    check?=CheckSuffix
;

// e.g. h4  a6  e8=Q
PawnPush:
    to_file=FILE_LETTER
    to_rank=RANK_DIGIT
    promotion?=PromotionSuffix
    check?=CheckSuffix
;

PromotionSuffix:
    '=' piece=PieceLetter
;

CheckSuffix:
    /[+#]/
;

PieceLetter:
    /[KQRBN]/
;

FILE_LETTER:
    /[a-h]/
;

RANK_DIGIT:
    /[1-8]/
;

Result:
    /1-0|0-1|1\/2-1\/2|\*/
;

QuotedString:
    /\"[^\"]*\"/
;
